# =============================================================================
# Interview Engine — Environment Variables
# Copy to .env and fill in required values
# =============================================================================

# --- Authentication ---
# REQUIRED — secret key for JWT signing (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
JWT_SECRET_KEY=
# OPTIONAL — default: HS256
JWT_ALGORITHM=HS256
# OPTIONAL — default: 1440 (24 hours)
JWT_EXPIRY_MINUTES=1440

# --- CORS ---
# OPTIONAL — comma-separated list of allowed origins. Default: http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_ORIGINS=

# --- LLM Providers ---
# REQUIRED — set at least one of OPENROUTER_API_KEY or GEMINI_API_KEY
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# --- Models (optional — defaults shown) ---
MODEL_INTERVIEW=gemini-2.0-flash
MODEL_JUDGE_1=gemini-2.0-flash
MODEL_JUDGE_2=gemini-2.5-flash
MODEL_JUDGE_3=gemini-2.5-flash-lite
MODEL_FAST=gemini-2.0-flash
MODEL_EMBEDDING=gemini-embedding-001

# --- Infrastructure (REQUIRED) ---
POSTGRES_URL=postgresql+asyncpg://talentscout:talentscout@localhost:5433/talentscout
REDIS_URL=redis://localhost:6379/0
CHROMA_HOST=localhost
CHROMA_PORT=8000

# --- Database Pool (optional) ---
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# --- Voice (REQUIRED) ---
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
INTERVIEW_VOICE_ID=
GOOGLE_STT_CREDENTIALS_JSON=
CARTESIA_API_KEY=
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_STT_MODEL=whisper-large-v3-turbo
EDGE_TTS_VOICE=en-US-GuyNeural

# --- Observability (optional) ---
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=talent-scout-dev

# --- Pipeline weights (must sum to 1.0) ---
INTERVIEW_WEIGHT=0.60
ASSESSMENT_WEIGHT=0.30
SPEECH_WEIGHT=0.05
SCREENING_WEIGHT=0.05

# --- Scoring thresholds ---
ADVANCE_THRESHOLD=0.75
HOLD_THRESHOLD=0.50
MAX_QUESTIONS=10

# --- Rate limits (requests per minute per model) ---
RPM_LIMIT_GPT4=500
RPM_LIMIT_CLAUDE=400
RPM_LIMIT_GEMINI=1000
